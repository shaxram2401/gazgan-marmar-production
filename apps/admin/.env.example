# ============================================================
# FIREBASE — Web SDK (public)
# ============================================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=gazgan-marmo.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=gazgan-marmo
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=gazgan-marmo.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ============================================================
# FIREBASE — Admin SDK (server, base64-encoded service account)
# ============================================================
FIREBASE_ADMIN_CREDENTIALS_B64=

# ============================================================
# SESSION
# ============================================================
SESSION_COOKIE_NAME=__gm_session
SESSION_MAX_AGE=432000

# ============================================================
# CRON / BACKUP / MONITORING — protect endpoints
# ============================================================
CRON_SECRET=                        # long random string
BACKUP_BUCKET=gazgan-marmo-backups  # GCS bucket for Firestore exports
ALERT_WEBHOOK_URL=                  # optional Slack / Discord webhook for alerts
ALERT_EMAIL_TO=admin@gazganmarmo.uz

# ============================================================
# SECURITY
# ============================================================
RATE_LIMIT_LOGIN=5                  # attempts / minute / IP
RATE_LIMIT_WINDOW_MS=60000
ALLOWED_LOGIN_COUNTRIES=            # optional: "UZ,RU,US" — empty = all

